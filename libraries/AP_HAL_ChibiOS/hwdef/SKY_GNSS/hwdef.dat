# hw definition file for processing by chibios_pins.py
# 用于 chibios_pins.py 处理的硬件定义文件

# MCU class and specific type
# MCU类型和具体型号
MCU STM32F4xx STM32F412Rx

# bootloader starts firmware at 64k
# 引导程序在64K处启动固件
FLASH_RESERVE_START_KB 64

# store parameters in pages 2 and 3
# 在第2和第3页存储参数
STORAGE_FLASH_PAGE 2
define HAL_STORAGE_SIZE 8192

# board ID for firmware load
# 固件加载的板子ID
APJ_BOARD_ID 1100

# setup build for a peripheral firmware
# 设置为外设固件构建
env AP_PERIPH 1

# 使用定时器5
STM32_ST_USE_TIMER 5

# 晶振频率
OSCILLATOR_HZ 16000000

# 系统时钟频率设置
define CH_CFG_ST_FREQUENCY 1000000

# assume 512k flash part
# 假定512K闪存
FLASH_SIZE_KB 512

# 串口输出设置
STDOUT_SERIAL SD1
STDOUT_BAUDRATE 57600

# order of UARTs
# UART串口顺序
SERIAL_ORDER USART1 EMPTY EMPTY USART2

# a LED to flash
# LED闪烁引脚
PB12 LED OUTPUT LOW

# USART1 for debug
# USART1用于调试
PB6 USART1_TX USART1 NODMA
PB7 USART1_RX USART1 NODMA
define DEFAULT_SERIAL0_BAUD 57600

# USART2 for GPS
# USART2用于GPS
PA2 USART2_TX USART2 NODMA
PA3 USART2_RX USART2 NODMA

# SWD调试接口
PA13 JTMS-SWDIO SWD
PA14 JTCK-SWCLK SWD

# only one I2C bus in normal config
# 仅配置一个I2C总线
PB4 I2C3_SDA I2C3
PA8 I2C3_SCL I2C3

# I2C配置
define HAL_USE_I2C TRUE
define STM32_I2C_USE_I2C3 TRUE
define HAL_I2C_CLEAR_ON_TIMEOUT 0
define HAL_I2C_INTERNAL_MASK 0

# I2C总线顺序
I2C_ORDER I2C3

# only one SPI bus in normal config
# SPI总线引脚配置
PA5 SPI1_SCK SPI1
PA6 SPI1_MISO SPI1
PA7 SPI1_MOSI SPI1

# SPI片选信号
PA4 MAG_CS CS


# SPI设备配置
SPIDEV rm3100 SPI1 DEVID1    MAG_CS MODE0  1*MHZ  1*MHZ


# 指南针配置

COMPASS RM3100 SPI:rm3100 false ROTATION_PITCH_180

# 气压计配置

BARO ICP201XX I2C:0:0x63
BARO ICP201XX I2C:0:0x64

# PWM输出用于蜂鸣器
PB10 TIM2_CH3 TIM2 GPIO(77) LOW ALARM

# 安全LED，低电平有效
PB1 SAFE_LED OUTPUT HIGH
define SAFE_LED_ON 0

# 安全按钮
PB3 SAFE_BUTTON INPUT PULLDOWN

# WS2812 LED配置
PB0 TIM3_CH3 TIM3 PWM(1)

# 允许无气压计初始化
define HAL_BARO_ALLOW_INIT_NO_BARO

# ADC相关配置
define HAL_USE_ADC FALSE
define STM32_ADC_USE_ADC1 FALSE
define HAL_DISABLE_ADC_DRIVER TRUE

# 禁用GPIO中断
define HAL_NO_GPIO_IRQ

# 禁用RCIN线程以节省内存
define HAL_NO_RCIN_THREAD

# 其他功能配置
define HAL_USE_RTC FALSE
define DISABLE_SERIAL_ESC_COMM TRUE
define DMA_RESERVE_SIZE 0
define HAL_DISABLE_LOOP_DELAY

# CAN总线支持配置
PB8 CAN1_RX CAN1
PB9 CAN1_TX CAN1
PB5 GPIO_CAN1_SILENT OUTPUT PUSHPULL SPEED_LOW LOW

# CAN总线节点名称
define CAN_APP_NODE_NAME "org.ardupilot.sky_gnss"

# 禁用监视线程
define HAL_NO_MONITOR_THREAD

# 设备线程栈大小
define HAL_DEVICE_THREAD_STACK 768

# 设置较小的参数表
define AP_PARAM_MAX_EMBEDDED_PARAM 256

# 禁用双GPS和GPS混合以节省闪存空间
define GPS_MAX_RECEIVERS 1
define GPS_MAX_INSTANCES 1
define HAL_COMPASS_MAX_SENSORS 1

# 启用GPS+磁罗盘+气压计+蜂鸣器+LED功能
define HAL_PERIPH_ENABLE_GPS
define HAL_PERIPH_ENABLE_MAG
define HAL_PERIPH_ENABLE_BARO

# 直接控制neopixel LED以实现启动时的'彩虹'效果
define HAL_PERIPH_NEOPIXEL_CHAN_WITHOUT_NOTIFY 0
define HAL_PERIPH_NEOPIXEL_COUNT_WITHOUT_NOTIFY 8

# 启用蜂鸣器
define HAL_PERIPH_ENABLE_BUZZER_WITHOUT_NOTIFY 1

# 默认LED类型
define DEFAULT_NTF_LED_TYPES 455
